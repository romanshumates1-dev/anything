# Live DB for local Layer C runs (use a Neon BRANCH url, not prod)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Twilio production config
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_MESSAGING_SERVICE_SID=MGxxxx
# or TWILIO_FROM_NUMBER=+15551234567
TWILIO_NUMBER_TYPE=10dlc
OWNER_NUMBER=+15559876543

# Set to 1 to enable the live flow runner (flows-live.test.ts). Unset = skipped.
RUN_LIVE_FLOWS=0

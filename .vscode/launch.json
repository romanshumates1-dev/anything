{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: debug server",
      "type": "node-terminal",
      "request": "launch",
      "command": "yarn workspace @anything/web dev",
      "serverReadyAction": {
        "pattern": "- Local: (https?://.+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Vitest: run current file",
      "type": "node-terminal",
      "request": "launch",
      "command": "yarn vitest run ${relativeFile}"
    },
    {
      "name": "Attach to process",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
